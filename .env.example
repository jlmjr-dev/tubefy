# Tubefy configuration. Copy to `.env.local` and fill in your own client ids.
# Full walkthrough: SETUP.md

# --- Spotify ---------------------------------------------------------------
# Create an app at https://developer.spotify.com/dashboard
# Register this exact redirect URI on the app: http://127.0.0.1:5173/callback
# (Spotify no longer accepts `localhost` as a redirect host.)
VITE_SPOTIFY_CLIENT_ID=

# --- Google / YouTube ------------------------------------------------------
# In Google Cloud console: enable "YouTube Data API v3", create an OAuth client
# of type "Web application", and add http://127.0.0.1:5173 as an authorized
# JavaScript origin. Add your Google account as a Test user on the consent screen.
VITE_GOOGLE_CLIENT_ID=

# --- Optional --------------------------------------------------------------
# Cap tracks processed per conversion. YouTube allows ~100 search calls/day and
# Tubefy runs one search per track, so keep this comfortably under 100.
# VITE_MAX_TRACKS=50

# Override the Spotify redirect URI (defaults to <origin>/callback).
# VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback
